#!/usr/bin/env bash

# Печатать выполняемую команду оболочки
#set -x
# Прерывать выполнение сценария при ошибке
set -e

# Проверка на наличие CAUSTIC_PATH
if [ -z "$CAUSTIC_PATH" ]; then
  echo "Ошибка: переменная окружения CAUSTIC_PATH не установлена."
  exit 1
fi

# Получение переменных от luarocks
LUA_VER="5.4"
LUA_PATH_STR=$(luarocks --local --lua-version=$LUA_VER path --lr-path)
LUA_CPATH_STR=$(luarocks --local --lua-version=$LUA_VER path --lr-cpath)
LUAROCKS_BIN=$(luarocks --local --lua-version=$LUA_VER path --lr-bin)

# Добавляем tl_dst/?.lua в путь
CAUSTIC_MODULE_PATH="$CAUSTIC_PATH/tl_dst/?.lua"

#echo $CAUSTIC_MODULE_PATH

# Объединение путей.
# NOTE: `;;` в начале LUA_PATH/LUA_CPATH критично. По семантике Lua `;;`
# раскрывается в дефолтный package.path/cpath текущего интерпретатора.
# Без `;;` luarocks, запускаемый рекурсивно из lua5.4 (через `koh make -c` /
# `koh compile_flags` в actions.project), наследует только 5.4-пути и
# замещает ими свой package.path. Shebang luarocks — `lua-any`, который
# исполняет его под lua5.1 (первый установленный из `5.1 5.3 5.4`); получив
# 5.4-пути вместо 5.1-дефолта, lua5.1 не находит
# /usr/share/lua/5.1/luarocks/core/cfg.lua и падает на require.
# С `;;` lua5.1 подставляет свой 5.1-дефолт и находит cfg.lua, а lua5.4
# (финальный caustic.lua) — 5.4-дефолт + luarocks-пути + tl_dst.
export PATH="$LUAROCKS_BIN:$PATH"
export LUA_PATH=";;$LUA_PATH_STR;$CAUSTIC_MODULE_PATH"
export LUA_CPATH=";;$LUA_CPATH_STR"

# Запуск Caustic
ASAN_OPTIONS=verify_asan_link_order=0 lua5.4 "$CAUSTIC_PATH/tl_dst/caustic.lua" "$@"
